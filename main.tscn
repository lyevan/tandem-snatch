[sub_resource type="Shader" id="Shader_lquwl"]
code = "shader_type sky;
render_mode use_debanding;

uniform vec4 sky_top_color : source_color = vec4(0.385, 0.454, 0.55, 1.0);
uniform vec4 sky_horizon_color : source_color = vec4(0.646, 0.656, 0.67, 1.0);
uniform float inv_sky_curve : hint_range(1, 100) = 4.0;
uniform vec4 ground_bottom_color : source_color = vec4(0.2, 0.169, 0.133, 1.0);
uniform vec4 ground_horizon_color : source_color = vec4(0.646, 0.656, 0.67, 1.0);
uniform float inv_ground_curve : hint_range(1, 100) = 30.0;
uniform float sun_angle_max = 0.877;
uniform float inv_sun_curve : hint_range(1, 100) = 22.78;
uniform float exposure : hint_range(0, 128) = 1.0;

uniform sampler2D sky_cover : filter_linear, source_color, hint_default_black;
uniform vec4 sky_cover_modulate : source_color = vec4(1.0, 1.0, 1.0, 1.0);

// Cloud Controls
uniform sampler2D cloud_texture;
uniform sampler2D cloud_texture2;
uniform vec2 cloud_direction = vec2(1.0, 0.2);
uniform vec2 cloud_direction2 = vec2(-0.5, 0.8);
uniform vec2 cloud_scale = vec2(0.05, 0.05);
uniform float cloud_distance = 0.0;
uniform float cloud_coverage : hint_range(0.0, 1.0) = 0.5;
uniform float cloud_softness : hint_range(0.01, 1.0) = 0.25;

void sky() {
	float v_angle = clamp(EYEDIR.y, -1.0, 1.0);
	vec3 sky = mix(sky_top_color.rgb, sky_horizon_color.rgb, clamp(pow(1.0 - v_angle, inv_sky_curve), 0.0, 1.0));

	if (LIGHT0_ENABLED) {
		float sun_angle = dot(LIGHT0_DIRECTION, EYEDIR);
		float sun_size = cos(LIGHT0_SIZE);
		if (sun_angle > sun_size) {
			sky = LIGHT0_COLOR * LIGHT0_ENERGY;
		} else if (sun_angle > sun_angle_max) {
			float c2 = (sun_size - sun_angle) / (sun_size - sun_angle_max);
			sky = mix(sky, LIGHT0_COLOR * LIGHT0_ENERGY, clamp(pow(1.0 - c2, inv_sun_curve), 0.0, 1.0));
		}
	}

	if (LIGHT1_ENABLED) {
		float sun_angle = dot(LIGHT1_DIRECTION, EYEDIR);
		float sun_size = cos(LIGHT1_SIZE);
		if (sun_angle > sun_size) {
			sky = LIGHT1_COLOR * LIGHT1_ENERGY;
		} else if (sun_angle > sun_angle_max) {
			float c2 = (sun_size - sun_angle) / (sun_size - sun_angle_max);
			sky = mix(sky, LIGHT1_COLOR * LIGHT1_ENERGY, clamp(pow(1.0 - c2, inv_sun_curve), 0.0, 1.0));
		}
	}

	if (LIGHT2_ENABLED) {
		float sun_angle = dot(LIGHT2_DIRECTION, EYEDIR);
		float sun_size = cos(LIGHT2_SIZE);
		if (sun_angle > sun_size) {
			sky = LIGHT2_COLOR * LIGHT2_ENERGY;
		} else if (sun_angle > sun_angle_max) {
			float c2 = (sun_size - sun_angle) / (sun_size - sun_angle_max);
			sky = mix(sky, LIGHT2_COLOR * LIGHT2_ENERGY, clamp(pow(1.0 - c2, inv_sun_curve), 0.0, 1.0));
		}
	}

	if (LIGHT3_ENABLED) {
		float sun_angle = dot(LIGHT3_DIRECTION, EYEDIR);
		float sun_size = cos(LIGHT3_SIZE);
		if (sun_angle > sun_size) {
			sky = LIGHT3_COLOR * LIGHT3_ENERGY;
		} else if (sun_angle > sun_angle_max) {
			float c2 = (sun_size - sun_angle) / (sun_size - sun_angle_max);
			sky = mix(sky, LIGHT3_COLOR * LIGHT3_ENERGY, clamp(pow(1.0 - c2, inv_sun_curve), 0.0, 1.0));
		}
	}

	vec3 ground = mix(ground_bottom_color.rgb, ground_horizon_color.rgb, clamp(pow(1.0 + v_angle, inv_ground_curve), 0.0, 1.0));
	
	// --- UPGRADED CLOUD LOGIC ---
	// Project UVs onto the sky dome (preventing division by zero at the horizon)
	vec2 sky_uv = EYEDIR.xz / max(EYEDIR.y, 0.001);
	
	// 1. Domain Warping: Sample texture 2 first to generate an organic distortion offset
	vec2 uv2 = (sky_uv * cloud_scale * 0.7) + (TIME * cloud_direction2 * 0.0005);
	vec2 warp_offset = (texture(cloud_texture2, uv2).rg - 0.5) * 0.2; 
	
	// 2. Main Sample: Apply the warp offset to texture 1's UV coordinates
	vec2 uv1 = (sky_uv * cloud_scale) + (TIME * cloud_direction * 0.0008) + warp_offset;
	float cloud_noise = texture(cloud_texture, uv1).r;
	
	// 3. Shape & Density: Use smoothstep to turn noise into fluffy cloud shapes
	float threshold = 1.0 - cloud_coverage;
	float density = smoothstep(threshold, threshold + cloud_softness, cloud_noise);
	
	// 4. Horizon Fade: Smoothly fade clouds out in the distance
	float horizon_fade = clamp(pow(max(EYEDIR.y, 0.0), 0.4), 0.0, 1.0);
	density *= horizon_fade;
	
	// 5. Cloud Lighting: Give clouds volume by tinting their undersides slightly darker
	vec3 cloud_color = mix(sky_horizon_color.rgb * 0.9, vec3(1.0), density);
	
	// Blend the clouds naturally over the sky background
	sky = mix(sky, cloud_color, density);
	// ----------------------------

	COLOR = mix(ground, sky, step(0.0, EYEDIR.y)) * exposure;
}"

